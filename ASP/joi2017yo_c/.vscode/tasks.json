{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "OJ Test",
      "type": "shell",
      "command": "oj",
      "args": [
        "test",
        "-c",
        "${config:python.defaultInterpreterPath} main.py",
        "-d",
        "input"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "OJ Submit",
      "type": "shell",
      "command": "oj",
      "args": [
        "submit",
        "-l",
        "6083",
        "https://atcoder.jp/contests/joi2017yo/tasks/joi2017yo_c",
        "main.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}

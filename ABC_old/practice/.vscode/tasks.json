{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "args": [
        "-std=c++20",
        "-O2",
        "-Wall",
        "-Wextra",
        "main.cpp",
        "-o",
        "main.exe"
      ],
      "label": "Build C++ (Release)",
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "problemMatcher": [
        ""
      ],
      "command": "g++",
      "presentation": {
        "panel": "shared",
        "focus": false,
        "reveal": "always",
        "echo": true
      }
    },
    {
      "type": "shell",
      "args": [
        "-std=c++20",
        "-g",
        "-DDEBUG",
        "-Wall",
        "-Wextra",
        "main.cpp",
        "-o",
        "main_debug.exe"
      ],
      "label": "Build C++ (Debug)",
      "group": "build",
      "problemMatcher": [
        ""
      ],
      "command": "g++",
      "presentation": {
        "panel": "shared",
        "focus": false,
        "reveal": "always",
        "echo": true
      }
    },
    {
      "type": "shell",
      "label": "Run C++ (with input)",
      "group": {
        "isDefault": true,
        "kind": "test"
      },
      "dependsOn": "Build C++ (Release)",
      "command": "Get-Content in_a.txt | ./main.exe",
      "presentation": {
        "panel": "shared",
        "focus": true,
        "reveal": "always",
        "echo": true
      }
    },
    {
      "group": "test",
      "presentation": {
        "panel": "shared",
        "focus": true,
        "reveal": "always",
        "echo": true
      },
      "type": "shell",
      "label": "Run Python (with input)",
      "command": "Get-Content in_a.txt | python main.py"
    }
  ]
}
